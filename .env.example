APP_NAME="Barangay Cantupa"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Local: sqlite. Production: use Supabase Postgres connection string.
DB_CONNECTION=sqlite
# DB_CONNECTION=pgsql
# DB_HOST=db.xxxxx.supabase.co
# DB_PORT=5432
# DB_DATABASE=postgres
# DB_USERNAME=postgres
# DB_PASSWORD=
# Or use one URI (Laravel reads DB_URL; DATABASE_URL also works in config):
# DB_URL=postgresql://postgres:...@db.xxxxx.supabase.co:5432/postgres

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# -----------------------------------------------------------------------------
# Supabase (Auth + optional Postgres + Storage)
# Dashboard: https://supabase.com/dashboard → Project Settings → API
# Never commit real keys. Copy this file to .env and fill in your project values.
# -----------------------------------------------------------------------------
SUPABASE_ENABLED=false
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# Uploads: "public" for local disk + php artisan storage:link
# Production: create a Storage bucket, S3 access keys (Storage → S3), then set supabase disk.
FILESYSTEM_UPLOAD_DISK=public

# Supabase Storage (S3-compatible). Storage → S3 → create access key.
SUPABASE_STORAGE_BUCKET=
SUPABASE_STORAGE_ACCESS_KEY=
SUPABASE_STORAGE_SECRET_KEY=
SUPABASE_STORAGE_REGION=us-east-1
SUPABASE_STORAGE_ENDPOINT=https://YOUR_PROJECT_REF.supabase.co/storage/v1/s3
SUPABASE_STORAGE_USE_PATH_STYLE=true
# Public URL base for objects (bucket must allow public read, or use signed URLs later).
# Example: https://YOUR_PROJECT_REF.supabase.co/storage/v1/object/public/YOUR_BUCKET

SUPABASE_STORAGE_PUBLIC_URL=

# Generic AWS (optional; not required when using supabase disk above)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# -----------------------------------------------------------------------------
# Vercel — Project → Settings → Environment Variables (Production)
#
# Vercel injects VERCEL=1; the app then defaults to stderr logging, array cache,
# sync queue, and /tmp view compile (no need to duplicate those unless you want
# to override). vercel.json extras may not reach PHP — do not rely on them alone.
#
# Minimum (matches a typical Supabase + Laravel setup):
#   APP_KEY=base64:...                    # php artisan key:generate --show
#   APP_URL=https://your-app.vercel.app   # exact HTTPS URL (no trailing slash)
#   APP_ENV=production
#   APP_DEBUG=false                       # true only briefly to debug; then false
#   DB_CONNECTION=pgsql
#   DATABASE_URL=postgresql://...         # Supabase: Settings → Database → URI
#                                         # (Laravel also reads DB_URL if you prefer)
#
# Optional overrides (only if you know you need them):
#   LOG_CHANNEL=stderr
#   SESSION_DRIVER=database               # requires `sessions` table (default migration)
#   CACHE_STORE=array
#   QUEUE_CONNECTION=sync
#   DB_SSLMODE=require                    # if Postgres SSL errors appear
#
# Supabase Auth (required if SUPABASE_ENABLED=true in app — signup/login via Supabase):
#   SUPABASE_ENABLED=true
#   SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
#   SUPABASE_ANON_KEY=eyJ...
#   SUPABASE_SERVICE_ROLE_KEY=eyJ...      # server only; staff user provisioning
#
# After first deploy: run migrations once against the same DB:
#   php artisan migrate --force
# -----------------------------------------------------------------------------
